# ==========================================
# 🗂️ Project Specific Ignored Files
# ==========================================
# Credentials (Crucial!)
.env
.env.local

# Local Diagnostic Logs
logs/*.log
logs/pipeline.log

# System-Generated PDFs and Texts
outputs/*.pdf
outputs/*.txt
