# =========================================================================
# 🚀 Internship Pipeline Configuration Template
# =========================================================================
# Copy this file to a new file named '.env' and fill in your credentials.
# NEVER commit the actual '.env' file containing secrets to Git/GitHub!

# 📧 Gmail Alert Settings
# SENDER_EMAIL: The Gmail address sending the job alert report
SENDER_EMAIL=adithyaadi104@gmail.com

# SENDER_APP_PASSWORD: A 16-character Google App Password (not your normal password!)
# Get it at: https://myaccount.google.com/security -> App Passwords
SENDER_APP_PASSWORD=your_16_character_app_password_here

# RECEIVER_EMAIL: The email address that will receive the alert and attached files
RECEIVER_EMAIL=adithyaadi104@gmail.com

# 🤖 Ollama Local AI Model Settings
# OLLAMA_MODEL: The exact name of the Ollama model running locally (default: llama3.2:3b)
OLLAMA_MODEL=llama3.2:3b
